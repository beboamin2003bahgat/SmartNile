# =============================================================================
# Smart Nile — Environment Configuration Template
# =============================================================================
# Copy this file to .env in the project root (one level above backend/):
#   cp backend/.env.example .env
#
# Then fill in your real values.
# Lines starting with # are comments and are ignored.
# =============================================================================


# ── System ────────────────────────────────────────────────────────────────────
SYSTEM_NAME=SmartNile
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# Set to True for development without hardware.
# Set to False on the actual Raspberry Pi with sensors attached.
SIMULATION_MODE=True

# Unique ID for this monitoring mission. Change each time you deploy.
MISSION_ID=mission_001


# ── Firebase ──────────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Path to the service account JSON file.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=backend/config/firebase_credentials.json

# How many Firestore documents to write per batch (default: 20)
FIREBASE_BATCH_SIZE=20

# How often (seconds) to flush the offline SQLite buffer to Firebase (default: 10)
FIREBASE_FLUSH_INTERVAL=10.0


# ── AI Advisor (LLM) ──────────────────────────────────────────────────────────
# Which provider to use: "gemini" or "openai"
AI_PROVIDER=gemini

# Google Gemini API key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API key (fallback)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key


# ── YOLO / TFLite ─────────────────────────────────────────────────────────────
# Path to the plant detection model file
MODEL_PATH=backend/models/plant_detect.tflite

# Minimum confidence score to report a detection (0.0 – 1.0)
MODEL_CONFIDENCE=0.60

# Which inference backend to use: "tflite" (recommended) or "yolo"
YOLO_BACKEND=tflite

# Minimum seconds between detections of the same species (debounce)
DETECTION_DEBOUNCE=5.0


# ── Camera ────────────────────────────────────────────────────────────────────
# Which camera backend: "opencv" (USB/webcam) or "picamera2" (RPi Camera Module)
CAMERA_BACKEND=picamera2

# For OpenCV backend: which device index to open (usually 0)
CAMERA_INDEX=0

CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=5


# ── GPS (NEO-6M) ──────────────────────────────────────────────────────────────
# Serial port for the NEO-6M GPS module
# Raspberry Pi 5 primary UART: /dev/ttyAMA0
# USB-to-serial adapter: /dev/ttyUSB1 (check with: ls /dev/ttyUSB*)
GPS_PORT=/dev/ttyAMA0
GPS_BAUD=9600
GPS_TIMEOUT=2.0

# How often (seconds) to read and push a GPS fix
GPS_INTERVAL=1.0


# ── Arduino Nano (sensor serial) ──────────────────────────────────────────────
# Serial port for the Arduino Nano
# Usually /dev/ttyUSB0 when connected via USB
ARDUINO_PORT=/dev/ttyUSB0
ARDUINO_BAUD=9600

# How often (seconds) to poll all sensors
SENSOR_INTERVAL=2.0


# ── DS18B20 Temperature (1-Wire) ──────────────────────────────────────────────
# 1-Wire device base path (kernel driver)
# Enable with: echo "dtoverlay=w1-gpio" >> /boot/firmware/config.txt
DS18B20_BASE_PATH=/sys/bus/w1/devices


# ── Paths ─────────────────────────────────────────────────────────────────────
SQLITE_PATH=backend/data/offline_buffer.db
SNAPSHOTS_DIR=backend/data/snapshots
EXPORTS_DIR=backend/data/exports
LOGS_DIR=backend/data/logs


# ── Reports ───────────────────────────────────────────────────────────────────
# How often to auto-generate a report (hours). Default: 24
REPORT_INTERVAL_HOURS=24


# ── Maps ──────────────────────────────────────────────────────────────────────
# Used by the React dashboard (not by the Python backend directly)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
