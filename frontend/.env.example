# =============================================================================
# Smart Nile Frontend — Environment Variables
# =============================================================================
# Copy to .env.local in the frontend/ directory:
#   cp .env.example .env.local
#
# React only exposes variables prefixed with REACT_APP_ to the browser.
# NEVER commit .env.local to git.
# =============================================================================

# ── Firebase Web SDK ──────────────────────────────────────────────────────────
# Copy from: Firebase Console → Project Settings → Your apps → Web → SDK snippet
REACT_APP_FIREBASE_API_KEY=AIzaSy...
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Optional: force simulation (no Firebase calls at all) ────────────────────
# Set to "false" in production. "true" for local dev without Firebase.
REACT_APP_USE_FIREBASE=true

# ── Google Maps (used in future Google Maps integration) ─────────────────────
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
